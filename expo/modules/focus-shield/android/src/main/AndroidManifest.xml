<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

  <!--
    Required by FocusShieldService (the AccessibilityService that
    enforces app blocking). Signature-level — no runtime grant
    required. The user must still enable the service in the system
    Settings → Accessibility screen; the BIND_ACCESSIBILITY_SERVICE
    permission is what allows our service to be a candidate.
  -->
  <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

  <application>
    <!--
      FocusShieldService: the AccessibilityService that watches the
      foreground app and bounces the user into the gate when a
      blocked app is opened.

      Declared in the module's manifest with tools:node="merge" so
      the manifest merger combines it with the main app's manifest
      at build time. The android:name is the full class name of the
      Kotlin class in the focusshield package.

      The android:resource points to the AccessibilityService config
      XML in the same module, which lists the event types we want
      (TYPE_WINDOW_STATE_CHANGED only).

      tools:node="merge" is required because Android only allows ONE
      BIND_ACCESSIBILITY_SERVICE per app; the merger needs explicit
      instruction to combine this with whatever else is in the main
      app manifest.
    -->
    <service
        android:name="expo.modules.focusshield.FocusShieldService"
        android:label="@string/focus_shield_accessibility_summary"
        android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
        android:exported="false"
        tools:node="merge">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
          android:name="android.accessibilityservice"
          android:resource="@xml/focus_shield_accessibility" />
    </service>
  </application>
</manifest>
